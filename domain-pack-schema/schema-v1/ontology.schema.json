{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Pack Ontology",
  "type": "object",
  "required": ["parameters"],
  "properties": {
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "unit", "description", "required"],
        "properties": {
          "name":             { "type": "string", "pattern": "^[a-z_]+$" },
          "type":             { "enum": ["number", "string", "boolean", "range", "array"] },
          "unit":             { "type": "string", "description": "SI unit or 'unit_unknown'" },
          "description":      { "type": "string" },
          "required":         { "type": "boolean" },
          "canonical_values": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  }
}
