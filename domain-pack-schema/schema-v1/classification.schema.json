{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Pack Classification",
  "type": "object",
  "required": ["outcome_classes", "rules"],
  "properties": {
    "outcome_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name":        { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "condition", "outcome", "confidence_threshold"],
        "properties": {
          "field":                { "type": "string" },
          "condition":            { "type": "string", "description": "Expression evaluated against field value" },
          "outcome":              { "type": "string" },
          "confidence_threshold": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    }
  }
}
