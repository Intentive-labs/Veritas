{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Pack Hypothesis",
  "type": "object",
  "required": ["hypothesis_id", "version", "title", "description", "variables", "expected_direction", "confidence_threshold"],
  "properties": {
    "hypothesis_id":         { "type": "string" },
    "version":               { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "title":                 { "type": "string" },
    "description":           { "type": "string" },
    "variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role", "description"],
        "properties": {
          "name":        { "type": "string" },
          "role":        { "enum": ["independent", "dependent", "control", "confound"] },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "expected_direction": { "type": "string", "description": "e.g. 'positive', 'negative', 'non-linear'" },
    "confidence_threshold": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
